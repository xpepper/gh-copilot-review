#!/usr/bin/env bash

set -euo pipefail

print_help() {
  printf "🔍 Request a Copilot code review on a GitHub pull request\n"
  printf "\n"
  printf "\033[1mUSAGE\033[0m\n"
  printf "  gh copilot-review [<number> | <url>]\n"
  printf "\n"
  printf "\033[1mINHERITED FLAGS\033[0m\n"
  printf "  --help   Show help for command\n"
  printf "\n"
  printf "\033[1mARGUMENTS\033[0m\n"
  printf "  A pull request can be supplied as argument in any of the following formats:\n"
  printf "  - by number, e.g. \"123\";\n"
  printf "  - by URL, e.g. \"https://github.com/OWNER/REPO/pull/123\".\n"
  printf "\n"
  printf "  If no argument is provided, the PR associated with the current branch is used.\n"
  printf "\n"
  printf "\033[1mEXAMPLES\033[0m\n"
  printf "  $ gh-copilot-review 353\n"
  printf "  $ gh-copilot-review https://github.com/OWNER/REPO/pull/353\n"
  printf "  $ gh-copilot-review\n"
  printf "\n"
  printf "\033[1mLEARN MORE\033[0m\n"
  printf "  Use \`gh copilot-review --help\` for more information about this command.\n"
  printf "  Read the manual at https://github.com/ChrisCarini/gh-copilot-review\n"
}

if [[ "${1:-}" == "--help" ]]; then
  print_help
  exit 0
fi

# Function to extract repo from git remote
get_repo_from_git() {
  git_url=$(git remote get-url origin 2>/dev/null)
  if [ -z "$git_url" ]; then
    echo "❌ Error: Could not get git remote URL. Are you in a git repo?" >&2
    exit 1
  fi

  case "$git_url" in
    git@github.com:*)
      echo "$git_url" | sed -e 's|git@github.com:||' -e 's|\.git$||'
      ;;
    https://github.com/*)
      echo "$git_url" | sed -e 's|https://github.com/||' -e 's|\.git$||'
      ;;
    ssh://*@github.com/*)
      echo "$git_url" | sed -e 's|.*@github.com/||' -e 's|\.git$||'
      ;;
    *)
      echo "❌ Error: Unsupported git remote format: $git_url" >&2
      exit 1
      ;;
  esac
}

if [ $# -eq 0 ]; then
  # No argument provided — try to infer the PR from the current branch
  pr_number=$(gh pr view --json number -q .number 2>/dev/null || true)
  if [ -z "$pr_number" ]; then
    echo "❌ Error: No PR number or URL provided, and no open PR found for the current branch."
    echo ""
    print_help
    exit 1
  fi
  repo=$(get_repo_from_git)
  echo "ℹ️  Auto-detected PR #${pr_number} for the current branch."
else
  input="$1"

  case "$input" in
    ''|*[^0-9]*)
      # Assume it's a URL
      case "$input" in
        *github.com/*/pull/*)
          repo=$(printf '%s\n' "$input" | sed -E 's|.*github.com/([^/]+/[^/]+)/pull/[0-9]+.*|\1|')
          pr_number=$(printf '%s\n' "$input" | sed -E 's|.*/pull/([0-9]+).*|\1|')

          if [ -z "$repo" ] || [ -z "$pr_number" ]; then
            echo "❌ Error: Could not extract repo or PR number from URL."
            exit 1
          fi
          ;;
        *)
          echo "❌ Error: Invalid input. Provide a GitHub PR URL or PR number."
          exit 1
          ;;
      esac
      ;;
    *)
      # All digits → PR number, get repo from git
      pr_number="$input"
      repo=$(get_repo_from_git)
      if [ -z "$repo" ]; then
        echo "❌ Error: Could not determine repo from git remote."
        exit 1
      fi
      ;;
  esac
fi

# Make the API call
echo "🔍 Requesting Copilot Code Review on ${repo} PR #${pr_number}..."
set +e
response=$(gh api --method POST "/repos/${repo}/pulls/${pr_number}/requested_reviewers" \
  -f "reviewers[]=copilot-pull-request-reviewer[bot]" 2>&1)
status=$?
set -e

# Validate response
if [ $status -eq 0 ]; then
  echo "✅ Success: Requested Copilot Code Review on https://github.com/${repo}/pull/${pr_number}"
else
  echo "❌ Failure: Could not request Copilot Code Review on https://github.com/${repo}/pull/${pr_number}"
  # Only show debug info if any of the below are set
  #   - `DEBUG_COPILOT_REVIEW=true`
  #   - `ACTIONS_STEP_DEBUG=true`
  #   - `ACTIONS_RUNNER_DEBUG=true`
  #   - `RUNNER_DEBUG=1` (set when a user checks the `Enable debug logging` checkbox when re-running a job)
  if [ "${DEBUG_COPILOT_REVIEW:-}" = "true" ] || [ "${ACTIONS_STEP_DEBUG:-}" = "true" ] || [ "${ACTIONS_RUNNER_DEBUG:-}" = "true" ] || [ "${RUNNER_DEBUG:-}" = "1" ]; then
    echo "🔍 Debug Info:"
    echo "$response" | jq . || echo "$response"
  fi

  exit $status
fi
